---
import 'virtual:shipyard/css'
import { getImage } from 'astro:assets'
import { i18n } from 'astro:config/server'
import config from 'virtual:shipyard/config'
import type { ImageMetadata } from 'astro'
import { mapObjIndexed } from 'ramda'
import type {
  NavigationEntry,
  NavigationTree,
  Script,
} from '../../src/schemas/config'
import { cn } from '../../src/tools/cn'
import { getTitle } from '../../src/tools/title'
import {
  AnnouncementBar,
  GlobalDesktopNavigation,
  Npm2YarnScript,
  SidebarNavigation,
} from '../components'
import Footer from './Footer.astro'

type CustomMetaTag = {
  name?: string
  property?: string
  content: string
}

type PageImage = string | ImageMetadata

type Props = {
  frontmatter?: {
    title?: string
    description?: string
    keywords?: string[]
    image?: PageImage
    canonicalUrl?: string
    customMetaTags?: CustomMetaTag[]
    sidebarNavigation?: NavigationTree
  }
} & {
  title?: string
  description?: string
  keywords?: string[]
  image?: PageImage
  canonicalUrl?: string
  customMetaTags?: CustomMetaTag[]
  sidebarNavigation?: NavigationTree
}

const currentPath = Astro.url.pathname
const props = Astro.props.frontmatter || Astro.props

const isImageMetadata = (value: PageImage): value is ImageMetadata =>
  typeof value === 'object' && value !== null && 'src' in value

const toAbsoluteUrl = (url: string) => {
  if (/^https?:\/\//i.test(url)) return url
  if (!Astro.site) return url
  return new URL(url, Astro.site).href
}

type OgImageData = {
  src: string
  width?: number
  height?: number
  type?: string
}

const resolveOgImage = async (
  value: PageImage | undefined,
): Promise<OgImageData | undefined> => {
  if (!value) return undefined
  if (typeof value === 'string') return { src: value }
  if (!isImageMetadata(value)) return undefined
  // 1200x630 JPEG keeps OG cards under ~200 KB so WhatsApp/Telegram fetch the
  // preview; re-encoding via Sharp also strips EXIF.
  const optimized = await getImage({
    src: value,
    width: 1200,
    height: 630,
    format: 'jpeg',
    fit: 'cover',
  })
  return {
    src: optimized.src,
    width: 1200,
    height: 630,
    type: 'image/jpeg',
  }
}

const ogImageData = await resolveOgImage(props.image ?? config.defaultImage)
const ogImageUrl = ogImageData ? toAbsoluteUrl(ogImageData.src) : undefined
const ogImageAlt = props.description

const withLocale = (path: string) =>
  i18n ? `/${Astro.currentLocale}${path}` : path
const applyLocaleAndSetActive: (nav: NavigationTree) => NavigationTree =
  mapObjIndexed((entry: NavigationEntry) => ({
    ...entry,
    ...(entry.href ? { href: withLocale(entry.href) } : {}),
    active: entry.href === currentPath,
    ...(entry.subEntry
      ? { subEntry: applyLocaleAndSetActive(entry.subEntry) }
      : {}),
  }))

const navigation = applyLocaleAndSetActive(config.navigation)
const title = getTitle(config.title, props.title)
const hasSidebar = !!props.sidebarNavigation

// Helper function to render script attributes
const renderScriptAttributes = (script: Script) => {
  if (typeof script === 'string') {
    return { src: script }
  }
  return script
}
---

<html>
  <head>
    <meta charset="utf-8" />
    <title>
      {title}
    </title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={props.description} />
    {props.keywords && props.keywords.length > 0 && (
      <meta name="keywords" content={props.keywords.join(', ')} />
    )}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={props.description} />
    {ogImageData && ogImageUrl && (
      <>
        <meta property="og:image" content={ogImageUrl} />
        {ogImageData.width && (
          <meta property="og:image:width" content={String(ogImageData.width)} />
        )}
        {ogImageData.height && (
          <meta property="og:image:height" content={String(ogImageData.height)} />
        )}
        {ogImageData.type && (
          <meta property="og:image:type" content={ogImageData.type} />
        )}
        {ogImageAlt && (
          <meta property="og:image:alt" content={ogImageAlt} />
        )}
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:image" content={ogImageUrl} />
        {ogImageAlt && (
          <meta name="twitter:image:alt" content={ogImageAlt} />
        )}
      </>
    )}
    {props.canonicalUrl && (
      <link rel="canonical" href={props.canonicalUrl} />
    )}
    {props.customMetaTags?.map((tag) => (
      <meta
        {...(tag.name && { name: tag.name })}
        {...(tag.property && { property: tag.property })}
        content={tag.content}
      />
    ))}

    {config.scripts?.map((script) => {
      const attrs = renderScriptAttributes(script)
      return <script is:inline {...attrs}></script>
    })}
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col">
    {config.announcementBar && <AnnouncementBar config={config.announcementBar} />}
    <div class={cn("drawer grow", { "lg:drawer-open": hasSidebar })}>
      <input id="drawer" type="checkbox" class="drawer-toggle" />
      <div class="drawer-content flex flex-col overflow-x-hidden">
        <GlobalDesktopNavigation
          showBrand={!hasSidebar}
          brand={config.brand}
          navigation={navigation}
        >
          <slot name="navbarExtra" slot="navbarExtra" />
        </GlobalDesktopNavigation>
        <div class="grow">
          <div class="mx-auto max-w-7xl px-4 pb-12">
            <slot />
          </div>
        </div>
      </div>

      <div class="drawer-side z-40">
        <label for="drawer" aria-label="close sidebar" class="drawer-overlay"
        ></label>
        <SidebarNavigation
          brand={config.brand}
          global={navigation}
          local={props.sidebarNavigation}
        >
          <slot name="sidebarExtra" slot="sidebarExtra" />
        </SidebarNavigation>
      </div>
    </div>
    <Footer />
    <Npm2YarnScript />
  </body>
</html>
